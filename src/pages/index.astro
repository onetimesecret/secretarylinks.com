---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Card from '../components/Card.astro';
import FlowDiagram from '../components/FlowDiagram.astro';
import Countdown from '../components/Countdown.astro';
import SignupForm from '../components/SignupForm.astro';
import UseCaseCard from '../components/UseCaseCard.astro';

const flowSteps = [
  { icon: '&#128279;', label: 'Generate a Link', description: 'Create a unique, single-use collection URL' },
  { icon: '&#128233;', label: 'Send It', description: 'Copy the link or email it directly' },
  { icon: '&#128206;', label: 'They Submit', description: 'Recipient pastes text or attaches files' },
  { icon: '&#128274;', label: 'You View', description: 'Only the receipt holder can access it' },
  { icon: '&#128165;', label: "It's Gone", description: 'Viewed once, then permanently destroyed' },
];

const useCases = [
  { href: '/usecases/hr', emoji: '&#128188;', title: 'HR & Onboarding', description: 'Collect tax forms, IDs, banking details, and signed documents from new hires without emailing sensitive personal data back and forth.' },
  { href: '/usecases/legal', emoji: '&#9878;', title: 'Legal & Compliance', description: 'Request documents, testimony, and evidence from clients or witnesses. Maintain chain-of-custody with auditable access logs.' },
  { href: '/usecases/it-security', emoji: '&#128187;', title: 'IT & Security', description: 'Collect incident reports, screenshots, credentials for compromised accounts, or vulnerability details from reporters.' },
  { href: '/usecases/healthcare', emoji: '&#127973;', title: 'Healthcare', description: 'Patients submit insurance cards, medical records, consent forms, and photos through an encrypted, self-destructing channel.' },
  { href: '/usecases/journalism', emoji: '&#128240;', title: 'Journalism & Tips', description: 'Sources submit documents, photos, and statements through ephemeral links that leave no trace once viewed.' },
  { href: '/usecases/insurance', emoji: '&#128203;', title: 'Insurance Claims', description: 'Claimants submit photos of damage, receipts, police reports. Evidence flows securely into the case file.' },
];

const features = [
  { icon: '&#128737;', title: 'Passphrase Protection', text: 'Add an optional passphrase the recipient must enter before they can submit. A second factor for the collection channel itself.' },
  { icon: '&#127760;', title: 'Custom Domains', text: 'Use your own domain for collection links. Recipients see your brand, not ours. Builds trust, reduces friction.' },
  { icon: '&#128200;', title: 'Audit Trail', text: 'Know when a link was created, accessed, submitted to, and viewed. Every event is logged.' },
  { icon: '&#127759;', title: 'Regional Storage', text: 'Choose where submission data is stored to meet data residency and sovereignty requirements.' },
  { icon: '&#128268;', title: 'API & Integrations', text: 'Generate Secretary Links programmatically. Embed collection flows into your existing tools.' },
  { icon: '&#128736;', title: 'Branded Experience', text: 'Customize the collection page with your logo, colors, and messaging.' },
];

const comparison = [
  { feature: 'Direction', classic: 'You share a secret → they view it', secretary: 'You send a link → they submit to you' },
  { feature: 'Content types', classic: 'Text only', secretary: 'Text, images, files' },
  { feature: 'Self-destructing', classic: '✓', secretary: '✓' },
  { feature: 'Passphrase protection', classic: '✓', secretary: '✓' },
  { feature: 'Custom domains', classic: '✓', secretary: 'Coming soon' },
  { feature: 'Regional storage', classic: '✓', secretary: '✓' },
  { feature: 'Recipient needs account', classic: 'No', secretary: 'No' },
  { feature: 'File attachments', classic: '—', secretary: '✓' },
  { feature: 'API', classic: '✓', secretary: 'Coming soon' },
];
---

<Base title="Secretary Links — Secure Collection Links by Onetime Secret">

  <!-- ====== Hero ====== -->
  <section class="relative flex min-h-screen items-center overflow-hidden bg-surface-inv text-text-inverse">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.04]">
      <div class="absolute inset-0 bg-radial from-accent/100 at-[20%_50%] to-transparent"></div>
      <div class="absolute inset-0 bg-radial from-accent-secondary/80 at-[80%_20%] to-transparent"></div>
    </div>
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
         style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
    </div>

    <!-- Secretary bird silhouette -->
    <svg class="pointer-events-none absolute -right-[5%] top-1/2 -translate-y-1/2 w-[45%] max-w-[600px] opacity-[0.06] max-md:hidden" viewBox="0 0 600 600" fill="none">
      <g stroke="currentColor" stroke-width="1" fill="none">
        <ellipse cx="300" cy="240" rx="80" ry="100"/>
        <path d="M300 140 Q320 80 340 100 Q330 90 350 70 Q335 85 355 55" stroke-width="1.5"/>
        <path d="M300 140 Q280 80 260 100 Q270 90 250 70" stroke-width="1.5"/>
        <line x1="270" y1="340" x2="250" y2="480" stroke-width="2"/>
        <line x1="330" y1="340" x2="350" y2="480" stroke-width="2"/>
        <path d="M220 240 Q160 200 180 260 Q150 230 170 280" stroke-width="1.5"/>
        <path d="M380 240 Q440 200 420 260 Q450 230 430 280" stroke-width="1.5"/>
        <rect x="310" y="170" width="40" height="16" rx="8" stroke-width="1.5"/>
        <line x1="300" y1="178" x2="315" y2="178" stroke-width="1.5"/>
        <circle cx="300" cy="300" r="250" stroke-dasharray="8 12"/>
        <line x1="300" y1="30" x2="300" y2="60"/>
        <line x1="300" y1="540" x2="300" y2="570"/>
        <line x1="30" y1="300" x2="60" y2="300"/>
        <line x1="540" y1="300" x2="570" y2="300"/>
      </g>
    </svg>

    <div class="relative z-10 mx-auto max-w-7xl px-6 pt-32 lg:px-8">
      <div class="max-w-2xl">
        <!-- Eyebrow -->
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-accent/25 bg-accent/12 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent">
          <span class="size-1.5 rounded-full bg-accent animate-pulse-slow"></span>
          Early Access Opens April 1, 2026
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl">
          Collect anything.<br>
          <em class="not-italic text-accent">Securely.</em>
        </h1>

        <p class="mt-8 max-w-xl text-lg text-text-inverse/70 leading-relaxed sm:text-xl">
          Generate a unique link. Send it to anyone. They submit text, images, or files through it. Only you can view what they send. Then it's gone.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="#signup" class="rounded-lg bg-accent px-8 py-4 text-lg font-semibold text-accent-on transition hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-xl no-underline">
            Get Early Access
          </a>
          <a href="#how-it-works" class="rounded-lg border border-white/25 px-8 py-4 text-lg font-semibold text-text-inverse transition hover:border-white/50 hover:bg-white/5 no-underline">
            See How It Works
          </a>
        </div>

        <Countdown target="2026-04-01T00:00:00" />

        <div class="mt-8 inline-flex items-center gap-2 rounded-lg border border-red-accent/20 bg-red-accent/10 px-4 py-2 text-sm text-red-accent">
          Yes, April 1st. No, it's not a joke. We just have a sense of timing.
        </div>
      </div>
    </div>
  </section>

  <!-- ====== Powered by OTS ====== -->
  <Section variant="cream-dark">
    <p class="mx-auto text-center text-sm text-text-secondary" style="max-width: none;">
      Built on the same infrastructure trusted by over 15 million secrets shared through
      <a href="https://onetimesecret.com" target="_blank" rel="noopener" class="font-semibold">Onetime Secret</a>
      since 2012. Same infrastructure. Same ephemerality. New direction.
    </p>
  </Section>

  <!-- ====== The Problem ====== -->
  <Section id="problem">
    <SectionHeader subtitle="You need a document from a client. A photo from a witness. Login credentials from a vendor. So you send an email and hope for the best.">
      Collecting sensitive information is still a mess
    </SectionHeader>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
      <Card icon="&#9993;" title="Email trails">
        Sensitive files bouncing across inboxes, cached on servers, indexed by search, forwarded by accident. Every copy is a liability.
      </Card>
      <Card icon="&#128172;" title="Chat logs">
        Passwords pasted into Slack. Photos dropped into Teams. Screenshots in iMessage. Recoverable, searchable, subpoenaable.
      </Card>
      <Card icon="&#128230;" title="File sharing links">
        Shared drives with open permissions. Dropbox links that never expire. Google Docs accessible to "anyone with the link" forever.
      </Card>
    </div>
  </Section>

  <!-- ====== How It Works ====== -->
  <Section id="how-it-works" variant="dark">
    <SectionHeader subtitle="Instead of sharing outward, you create a secure channel for collecting inward. One link. One submission. Then it disappears.">
      Secretary Links flip the flow
    </SectionHeader>

    <FlowDiagram steps={flowSteps} />

    <div class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
      <div data-reveal>
        <div class="mb-4 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/12">
          <svg class="size-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
        <h3 class="mb-2 text-xl">No account required</h3>
        <p class="text-sm text-text-inverse/60 leading-relaxed">Your recipient doesn't need to sign up, install anything, or create a password. They just click and submit.</p>
      </div>
      <div data-reveal>
        <div class="mb-4 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/12">
          <svg class="size-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="mb-2 text-xl">Encrypted and ephemeral</h3>
        <p class="text-sm text-text-inverse/60 leading-relaxed">Submissions are encrypted at rest with unique per-secret keys and protected in transit. Once viewed, they're permanently destroyed.</p>
      </div>
      <div data-reveal>
        <div class="mb-4 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/12">
          <svg class="size-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="mb-2 text-xl">Configurable expiry</h3>
        <p class="text-sm text-text-inverse/60 leading-relaxed">Links auto-expire after a set time, whether used or not. You control the window.</p>
      </div>
      <div data-reveal>
        <div class="mb-4 flex size-12 items-center justify-center rounded-xl border border-accent/20 bg-accent/12">
          <svg class="size-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <h3 class="mb-2 text-xl">Text, images, &amp; files</h3>
        <p class="text-sm text-text-inverse/60 leading-relaxed">Secretary Links accept file attachments, photos, documents, and plain text in the same submission.</p>
      </div>
    </div>
  </Section>

  <!-- ====== Use Cases ====== -->
  <Section id="use-cases">
    <SectionHeader subtitle="Anywhere you need to collect something sensitive from someone outside your systems.">
      Built for how people actually work
    </SectionHeader>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
      {useCases.map(uc => (
        <UseCaseCard {...uc} />
      ))}
    </div>
  </Section>

  <!-- ====== Features ====== -->
  <Section id="features" variant="dark">
    <SectionHeader>The details matter</SectionHeader>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
      {features.map(f => (
        <Card icon={f.icon} title={f.title} dark>{f.text}</Card>
      ))}
    </div>
  </Section>

  <!-- ====== Comparison ====== -->
  <Section id="comparison">
    <SectionHeader subtitle="Same family. Different direction. Classic Onetime Secret is about sharing outward. Secretary Links are about collecting inward.">
      Classic OTS vs. Secretary Links
    </SectionHeader>

    <div class="overflow-x-auto" data-reveal>
      <table class="w-full border-collapse text-[0.95rem]">
        <thead>
          <tr>
            <th class="bg-surface-alt p-4 text-left font-display text-base"></th>
            <th class="bg-surface-alt p-4 text-left font-display text-base">Classic Onetime Secret</th>
            <th class="bg-surface-alt p-4 text-left font-display text-base">Secretary Links</th>
          </tr>
        </thead>
        <tbody>
          {comparison.map(row => (
            <tr>
              <td class="border-b border-border p-4 font-medium">{row.feature}</td>
              <td class="border-b border-border p-4">{row.classic === '✓' ? <span class="font-bold text-accent-secondary">✓</span> : row.classic}</td>
              <td class="border-b border-border p-4">{row.secretary === '✓' ? <span class="font-bold text-accent-secondary">✓</span> : row.secretary}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <!-- ====== Trust / OTS Connection ====== -->
  <Section variant="navy-light">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div data-reveal>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl">Twelve years of secrets kept</h2>
        <p class="mt-6 text-lg text-text-inverse/70 leading-relaxed">
          Onetime Secret has been the go-to for sharing sensitive information since 2012. No accounts required, no data retained, no traces left behind. Secretary Links brings that same philosophy to the other side of the exchange: secure collection.
        </p>
        <a href="https://onetimesecret.com" target="_blank" rel="noopener" class="mt-6 inline-flex rounded-lg border border-white/25 px-6 py-3 font-semibold text-text-inverse no-underline transition hover:border-white/50 hover:bg-white/5">
          Visit Onetime Secret &rarr;
        </a>
      </div>
      <div data-reveal>
        <div class="grid grid-cols-3 gap-8 text-center">
          {[
            { number: '12+', label: 'Years running' },
            { number: '15M+', label: 'Secrets shared' },
            { number: '0', label: 'Secrets retained' },
          ].map(stat => (
            <div>
              <div class="font-display text-4xl text-accent sm:text-5xl">{stat.number}</div>
              <div class="mt-2 text-sm text-text-inverse/50">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <!-- ====== CTA / Signup ====== -->
  <Section id="signup">
    <div class="relative overflow-hidden rounded-3xl bg-linear-to-br from-surface-inv to-surface-inv-alt px-8 py-20 text-center text-text-inverse sm:px-16" data-reveal>
      <div class="pointer-events-none absolute -top-1/2 -left-1/4 h-[200%] w-3/4 bg-radial from-accent/8 to-transparent"></div>
      <div class="relative z-10">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl">April 1st is not a drill</h2>
        <p class="mx-auto mt-4 text-lg text-text-inverse/70" style="max-width: 480px;">Be the first to try Secretary Links when early access opens.</p>
        <div class="mt-8">
          <SignupForm />
        </div>
      </div>
    </div>
  </Section>

</Base>
