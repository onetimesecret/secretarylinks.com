---
import Base from '../layouts/Base.astro';

// Social preview dimensions: 1200x630 (OG) scaled down for preview
const scale = 0.5;
const width = 1200 * scale;
const height = 630 * scale;
---

<Base title="Social Preview Concepts — Secretary Links">
  <main class="min-h-screen bg-surface py-20">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="font-display text-4xl text-text-primary mb-4">Social Preview Concepts</h1>
      <p class="text-text-secondary mb-4">Open Graph images for Twitter, Facebook, LinkedIn (1200x630)</p>
      <p class="text-text-muted text-sm mb-12">Shown at 50% scale. Click to view full size.</p>

      <div class="grid gap-12">

        <!-- 1. Minimal brand -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">1. Minimal Brand</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-surface-inv flex flex-col items-center justify-center">
              <div class="flex items-center gap-4 mb-6">
                <svg class="size-16 text-text-inverse" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="font-display text-4xl text-text-inverse">Secretary Links</span>
              </div>
              <p class="font-display text-2xl text-text-inverse/70">A secure collection service by Onetime Secret</p>
            </div>
          </div>
        </section>

        <!-- 2. Tagline focused -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">2. Tagline Focused</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-surface-inv flex flex-col items-center justify-center px-12">
              <p class="font-display text-3xl text-text-inverse text-center leading-snug mb-8">
                Generate a link. Collect what you need.<br/>
                <span class="text-accent">Then it's gone forever.</span>
              </p>
              <div class="flex items-center gap-3">
                <svg class="size-8 text-text-inverse/60" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="font-display text-xl text-text-inverse/60">Secretary Links</span>
              </div>
            </div>
          </div>
        </section>

        <!-- 3. Feature highlights -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">3. Feature Grid</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-surface-inv flex items-center justify-center">
              <div class="flex items-center gap-16">
                <!-- Left side -->
                <div class="flex items-center gap-3">
                  <svg class="size-10 text-text-inverse" viewBox="0 0 32 32" fill="none">
                    <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                    <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <div class="flex flex-col items-end">
                    <p class="font-display text-2xl text-text-inverse">Secretary Links</p>
                    <p class="text-text-inverse/50 text-xs">by Onetime Secret</p>
                  </div>
                </div>
                <!-- Right side - features -->
                <div class="flex flex-col justify-center gap-4 text-sm">
                <div class="flex items-center gap-2 text-text-inverse/80">
                  <svg class="size-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  One-time secure links
                </div>
                <div class="flex items-center gap-2 text-text-inverse/80">
                  <svg class="size-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Text, images, or files
                </div>
                <div class="flex items-center gap-2 text-text-inverse/80">
                  <svg class="size-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Only you can view
                </div>
                <div class="flex items-center gap-2 text-text-inverse/80">
                  <svg class="size-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Auto-deletes after viewing
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 4. Bold statement -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">4. Bold Statement</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-surface-inv flex items-center justify-center">
              <p class="font-display text-5xl text-text-inverse">A collection service.</p>
            </div>
            <!-- Logo watermark bottom right -->
            <div class="absolute bottom-6 right-8 flex items-center gap-2">
              <svg class="size-6 text-text-inverse/40" viewBox="0 0 32 32" fill="none">
                <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-text-inverse/40 text-sm">secretarylinks.com</span>
            </div>
          </div>
        </section>

        <!-- 5. Gradient accent -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">5. Gradient Accent</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-surface-inv">
              <!-- Gradient bar at top -->
              <div class="h-2 bg-gradient-to-r from-accent via-accent-secondary to-accent"></div>
              <div class="flex flex-col items-center justify-center h-full pb-4">
                <div class="flex items-center gap-4 mb-4">
                  <svg class="size-14 text-text-inverse" viewBox="0 0 32 32" fill="none">
                    <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                    <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="font-display text-4xl text-text-inverse">Secretary Links</span>
                </div>
                <p class="text-text-inverse/60 text-lg mb-1">Secure one-time collection links</p>
                <p class="text-accent text-sm">by Onetime Secret</p>
              </div>
            </div>
          </div>
        </section>

        <!-- 6. Use case hint -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">6. Use Case Hint</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-surface-inv flex">
              <!-- Left content -->
              <div class="flex-1 flex flex-col justify-center pl-12">
                <div class="flex items-center gap-3 mb-6">
                  <svg class="size-10 text-text-inverse" viewBox="0 0 32 32" fill="none">
                    <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                    <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="font-display text-2xl text-text-inverse">Secretary Links</span>
                </div>
                <p class="text-2xl text-text-inverse/80 leading-relaxed">
                  Securely collect sensitive info<br/>
                  <span class="text-text-inverse/50">without it lingering in email</span>
                </p>
              </div>
              <!-- Right side - subtle use case icons -->
              <div class="w-40 bg-surface-inv-alt flex flex-col items-center justify-center gap-4 text-text-inverse/30">
                <span class="text-xs uppercase tracking-wide">For</span>
                <div class="flex flex-col gap-2 text-xs text-center">
                  <span>HR</span>
                  <span>Legal</span>
                  <span>Healthcare</span>
                  <span>IT Security</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 7. Large icon -->
        <section>
          <h2 class="text-sm font-medium text-text-secondary uppercase tracking-wide mb-4">7. Icon Hero</h2>
          <div
            class="relative overflow-hidden rounded-lg shadow-xl"
            style={`width: ${width}px; height: ${height}px;`}
          >
            <div class="absolute inset-0 bg-gradient-to-br from-surface-inv to-surface-inv-deep flex items-center justify-center">
              <svg class="size-40 text-text-inverse/20 absolute" viewBox="0 0 32 32" fill="none">
                <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div class="relative text-center">
                <h1 class="font-display text-4xl text-text-inverse mb-2">Secretary Links</h1>
                <p class="text-text-inverse/60">A secure collection service by Onetime Secret</p>
              </div>
            </div>
          </div>
        </section>

      </div>

      <!-- Export instructions -->
      <section class="mt-16 p-6 rounded-lg bg-surface-alt">
        <h2 class="font-display text-xl text-text-primary mb-4">To Export</h2>
        <ol class="list-decimal list-inside space-y-2 text-text-secondary text-sm">
          <li>Pick a design above</li>
          <li>Create a standalone HTML file at full 1200x630 resolution</li>
          <li>Screenshot or use a tool like <code class="bg-surface px-1 rounded">pageres-cli</code> to capture as PNG</li>
          <li>Add to <code class="bg-surface px-1 rounded">public/og-image.png</code></li>
        </ol>
      </section>

    </div>
  </main>
</Base>
