---
import Base from '../layouts/Base.astro';
---

<Base title="Logo Concepts — Secretary Links">
  <main class="min-h-screen bg-surface-inv py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="font-display text-4xl text-text-inverse mb-4">Logo Concepts</h1>
      <p class="text-text-inverse/70 mb-12">Exploring icons that better represent secure link sharing for receiving sensitive information.</p>

      <div class="grid gap-8">

        <!-- Current -->
        <section class="rounded-xl bg-surface-inv-alt p-8">
          <h2 class="text-sm font-medium text-text-inverse/50 uppercase tracking-wide mb-6">Current</h2>
          <div class="flex items-center gap-6">
            <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
              <svg class="size-12" viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                <path d="M8 20 L16 10 L20 14 L24 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M24 8 L24 13 M24 8 L19 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="16" cy="22" r="2" fill="currentColor" opacity="0.4"/>
              </svg>
              Secretary Links
            </div>
            <span class="text-text-inverse/40 text-sm">Analytics/growth — doesn't convey security or link sharing</span>
          </div>
        </section>

        <!-- Concepts -->
        <section class="rounded-xl bg-surface-inv-alt p-8">
          <h2 class="text-sm font-medium text-text-inverse/50 uppercase tracking-wide mb-6">Concepts</h2>
          <div class="grid gap-10">

            <!-- 1. Sealed Envelope -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M7 12 L16 18 L25 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <rect x="7" y="12" width="18" height="12" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="16" cy="12" r="2.5" fill="currentColor" opacity="0.8"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Sealed envelope — receiving secure messages</span>
            </div>

            <!-- 2. Link with Lock -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M10 14 a4 4 0 0 1 4-4 h1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M10 14 a4 4 0 0 0 4 4 h1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M22 18 a4 4 0 0 1 -4 4 h-1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M22 18 a4 4 0 0 0 -4-4 h-1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <rect x="14" y="13" width="4" height="5" rx="0.5" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M15 13 v-1.5 a1.5 1.5 0 0 1 3 0 v1.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Chain link with lock — secure connection</span>
            </div>

            <!-- 3. Keyhole -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <circle cx="16" cy="13" r="4" stroke="currentColor" stroke-width="2"/>
                  <path d="M14 16 L14 23 L18 23 L18 16" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Keyhole — private access, only you can view</span>
            </div>

            <!-- 4. Inbox Arrow -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Inbox with arrow — receiving submissions</span>
            </div>

            <!-- 5. Shield Link -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M16 6 L24 9 L24 15 C24 20 20 24 16 26 C12 24 8 20 8 15 L8 9 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M12 15 h3 M17 15 h3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="15" cy="15" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="17" cy="15" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Shield with link — protected connection</span>
            </div>

            <!-- 6. Dissolving Link -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M9 16 a4 4 0 0 1 4-4 h2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M9 16 a4 4 0 0 0 4 4 h2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="20" cy="12" r="1" fill="currentColor" opacity="0.7"/>
                  <circle cx="23" cy="14" r="0.8" fill="currentColor" opacity="0.5"/>
                  <circle cx="21" cy="17" r="1.2" fill="currentColor" opacity="0.4"/>
                  <circle cx="24" cy="19" r="0.6" fill="currentColor" opacity="0.3"/>
                  <circle cx="19" cy="20" r="0.8" fill="currentColor" opacity="0.2"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Dissolving link — ephemeral, one-time access</span>
            </div>

            <!-- 7. Paper with Seal -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M10 7 L22 7 L22 25 L10 25 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M13 11 L19 11 M13 14 L17 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
                  <circle cx="16" cy="20" r="3" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M16 18.5 L16 21.5 M14.5 20 L17.5 20" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Document with seal — official, verified submission</span>
            </div>

            <!-- 8. Eye with Slash (Private) -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M6 16 C6 16 10 10 16 10 C22 10 26 16 26 16 C26 16 22 22 16 22 C10 22 6 16 6 16 Z" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="16" cy="16" r="3" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M22 10 L10 22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Hidden eye — private, only recipient can view</span>
            </div>

            <!-- 9. Arrow into Lock -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <rect x="11" y="14" width="10" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M13 14 v-2.5 a3 3 0 0 1 6 0 v2.5" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M7 18 L11 18 M7 18 L9 16 M7 18 L9 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Arrow into lock — secure intake</span>
            </div>

            <!-- 10. S monogram -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <path d="M20 10 C20 10 18 8 15 8 C11 8 9 10.5 9 12.5 C9 17 16 15 16 18 C16 20 14 22 11 22 C9 22 8 21 8 21" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <circle cx="22" cy="12" r="2" fill="currentColor" opacity="0.6"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Stylized S with dot — lettermark, hint of connection</span>
            </div>

            <!-- 11. 60s Secretary Bouffant - Silhouette -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <!-- Tall bouffant hair -->
                  <path d="M11 14 C11 6 13 4 16 4 C19 4 21 6 21 10 C22 10 23 11 23 13 C23 15 21 16 21 16 L21 18 C21 19 20 20 19 20 L13 20 C12 20 11 19 11 18 L11 16 C11 16 9 15 9 13 C9 11 10 10 11 10 C11 8 11 6 11 14 Z" fill="currentColor" opacity="0.9"/>
                  <!-- Face hint -->
                  <ellipse cx="16" cy="17" rx="3" ry="2.5" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                  <!-- Shoulders -->
                  <path d="M10 24 C10 21 12 20 16 20 C20 20 22 21 22 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">60s secretary silhouette — retro Mad Men vibes</span>
            </div>

            <!-- 12. 60s Bouffant - Outline style -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <!-- Big bouffant outline -->
                  <path d="M10 15 C10 7 12 5 16 5 C20 5 22 7 22 12 C23 12 24 13 24 14.5 C24 16 22.5 17 22 17 L22 18 L10 18 L10 17 C9.5 17 8 16 8 14.5 C8 13 9 12 10 12 C10 10 10 15 10 15 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <!-- Face -->
                  <circle cx="16" cy="21" r="3" stroke="currentColor" stroke-width="1.5"/>
                  <!-- Shoulders -->
                  <path d="M11 27 C11 24 13 23 16 23 C19 23 21 24 21 27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">60s bouffant outline — elegant line art</span>
            </div>

            <!-- 13. 60s Bouffant - Side profile -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <!-- Side profile with bouffant -->
                  <path d="M12 20 C12 20 10 18 10 15 C10 12 11 10 11 8 C11 5 13 4 16 4 C20 4 21 6 21 9 C21 11 20 12 20 14 L20 16 C20 17 19 18 18 19 L18 21 C18 22 17 23 16 23 L14 23 C13 23 12 22 12 21 Z" fill="currentColor" opacity="0.85"/>
                  <!-- Flip curl detail -->
                  <path d="M20 14 C21 14 22 15 21 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <!-- Collar -->
                  <path d="M12 23 L10 27 M18 23 L20 27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">60s profile with flip — classic secretary silhouette</span>
            </div>

            <!-- 14. Bouffant with Link symbol -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <!-- Simplified bouffant head -->
                  <ellipse cx="16" cy="10" rx="6" ry="5" fill="currentColor" opacity="0.8"/>
                  <!-- Face -->
                  <circle cx="16" cy="14" r="3" stroke="currentColor" stroke-width="1"/>
                  <!-- Chain link as necklace/collar -->
                  <path d="M12 19 a2 2 0 0 1 2-2 h1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M12 19 a2 2 0 0 0 2 2 h1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M20 19 a2 2 0 0 0 -2-2 h-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M20 19 a2 2 0 0 1 -2 2 h-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <!-- Shoulders -->
                  <path d="M9 26 C9 22 12 21 16 21 C20 21 23 22 23 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Bouffant with chain link necklace — secretary + links</span>
            </div>

            <!-- 15. Minimalist 60s head -->
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3 font-display text-2xl text-text-inverse">
                <svg class="size-12" viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                  <!-- Very minimal bouffant shape -->
                  <path d="M10 16 Q10 6 16 6 Q22 6 22 12 Q24 12 24 14 Q24 16 22 16 L22 18 Q22 20 20 20 L12 20 Q10 20 10 18 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  <!-- Simple face dots -->
                  <circle cx="14" cy="16" r="0.8" fill="currentColor"/>
                  <circle cx="18" cy="16" r="0.8" fill="currentColor"/>
                  <!-- Subtle smile -->
                  <path d="M14 18 Q16 19 18 18" stroke="currentColor" stroke-width="1" stroke-linecap="round" fill="none"/>
                </svg>
                Secretary Links
              </div>
              <span class="text-text-inverse/40 text-sm">Minimalist 60s face — friendly, approachable</span>
            </div>

          </div>
        </section>

        <!-- Size variations -->
        <section class="rounded-xl bg-surface-inv-alt p-8">
          <h2 class="text-sm font-medium text-text-inverse/50 uppercase tracking-wide mb-6">Size Test (pick your favorite above)</h2>
          <div class="flex items-end gap-8">
            <svg class="size-6 text-text-inverse" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
              <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="size-8 text-text-inverse" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
              <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="size-12 text-text-inverse" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
              <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="size-16 text-text-inverse" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
              <path d="M8 18 L8 23 L24 23 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 18 L12 18 L14 21 L18 21 L20 18 L24 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 7 L16 16 M12 12 L16 16 L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </section>

      </div>
    </div>
  </main>
</Base>
