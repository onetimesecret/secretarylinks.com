---
interface Props {
  target: string; // ISO date string
}

const { target } = Astro.props;
---

<div data-countdown={target} class="mt-10 flex gap-6" aria-label="Countdown to launch">
  {['Days', 'Hours', 'Minutes', 'Seconds'].map(label => (
    <div class="text-center">
      <span class="block font-mono text-4xl font-bold text-accent sm:text-5xl" data-countdown-unit={label.toLowerCase()}>00</span>
      <span class="mt-1 text-xs uppercase tracking-widest text-text-inverse/50">{label}</span>
    </div>
  ))}
</div>

<script>
  const el = document.querySelector('[data-countdown]') as HTMLElement;
  if (el) {
    const target = new Date(el.dataset.countdown!).getTime();
    const units = ['days', 'hours', 'minutes', 'seconds'];

    function update() {
      const diff = Math.max(0, target - Date.now());
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);

      [d, h, m, s].forEach((v, i) => {
        const span = el.querySelector(`[data-countdown-unit="${units[i]}"]`);
        if (span) span.textContent = String(v).padStart(2, '0');
      });

      if (diff <= 0) {
        el.innerHTML = '<span class="font-display text-3xl text-accent">It\'s here.</span>';
      }
    }

    update();
    setInterval(update, 1000);
  }
</script>
