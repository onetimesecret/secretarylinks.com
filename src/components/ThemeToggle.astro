---
const themes = [
  { id: 'light', label: 'Light' },
  { id: 'dark', label: 'Dark' },
  { id: 'sepia', label: 'Sepia' },
  { id: 'contrast', label: 'High Contrast' },
];
---

<div class="relative" data-theme-toggle>
  <button
    type="button"
    class="flex size-9 items-center justify-center rounded-lg text-text-inverse/70 transition hover:text-text-inverse hover:bg-white/10 focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface-inv focus-visible:outline-none"
    aria-label="Change theme"
    aria-expanded="false"
    aria-haspopup="menu"
    data-theme-btn
  >
    <!-- Sun (light) -->
    <svg data-icon="light" class="size-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <circle cx="12" cy="12" r="5"/>
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <!-- Moon (dark) -->
    <svg data-icon="dark" class="size-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
    </svg>
    <!-- Book (sepia) -->
    <svg data-icon="sepia" class="size-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2zM22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
    </svg>
    <!-- Half circle (high contrast) -->
    <svg data-icon="contrast" class="size-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 2a10 10 0 010 20z" fill="currentColor"/>
    </svg>
  </button>

  <div
    class="absolute right-0 top-full mt-2 hidden w-44 rounded-xl border border-white/10 bg-surface-inv p-1.5 shadow-xl"
    role="menu"
    data-theme-menu
  >
    {themes.map(t => (
      <button
        type="button"
        role="menuitemradio"
        aria-checked="false"
        data-theme-option={t.id}
        class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm text-text-inverse/70 transition hover:bg-white/10 hover:text-text-inverse focus-visible:bg-white/10 focus-visible:text-text-inverse focus-visible:outline-none"
      >
        {t.id === 'light' && <span class="size-4 rounded-full border-2 border-current bg-amber-200/60"></span>}
        {t.id === 'dark' && <span class="size-4 rounded-full border-2 border-current bg-indigo-400/40"></span>}
        {t.id === 'sepia' && <span class="size-4 rounded-full border-2 border-current bg-orange-300/50"></span>}
        {t.id === 'contrast' && <span class="size-4 rounded-full border-2 border-current overflow-hidden relative"><span class="absolute inset-0 w-1/2 bg-current"></span></span>}
        {t.label}
      </button>
    ))}
  </div>
</div>

<script>
  function getTheme(): string {
    return document.documentElement.dataset.theme || 'light';
  }

  function setTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = (theme === 'dark') ? 'dark' : 'light';
    localStorage.setItem('theme', theme);
    updateUI();
  }

  function updateUI() {
    const theme = getTheme();

    // Update button icon
    document.querySelectorAll('[data-theme-toggle] [data-icon]').forEach(el => {
      (el as HTMLElement).classList.toggle('hidden', el.getAttribute('data-icon') !== theme);
    });

    // Update menu active state
    document.querySelectorAll('[data-theme-option]').forEach(el => {
      const isActive = el.getAttribute('data-theme-option') === theme;
      el.toggleAttribute('data-active', isActive);
      el.setAttribute('aria-checked', String(isActive));
    });

    const themeLabels: Record<string, string> = { light: 'Light', dark: 'Dark', sepia: 'Sepia', contrast: 'High Contrast' };
    btn?.setAttribute('aria-label', `Change theme (current: ${themeLabels[theme] || theme})`);
  }

  // Toggle menu
  const btn = document.querySelector('[data-theme-btn]');
  const menu = document.querySelector('[data-theme-menu]');

  function closeMenu() {
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    btn?.focus();
  }

  btn?.addEventListener('click', () => {
    const opening = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(opening));
  });

  // Theme selection
  document.querySelectorAll('[data-theme-option]').forEach(el => {
    el.addEventListener('click', () => {
      setTheme(el.getAttribute('data-theme-option')!);
      closeMenu();
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('[data-theme-toggle]')) closeMenu();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // Keyboard navigation in menu
  menu?.addEventListener('keydown', (e) => {
    const items = [...menu.querySelectorAll('[role="menuitemradio"]')] as HTMLElement[];
    const idx = items.indexOf(document.activeElement as HTMLElement);
    if (e.key === 'ArrowDown') { e.preventDefault(); items[(idx + 1) % items.length]?.focus(); }
    if (e.key === 'ArrowUp') { e.preventDefault(); items[(idx - 1 + items.length) % items.length]?.focus(); }
  });

  updateUI();
</script>

<style>
  [data-theme-option][data-active] {
    color: var(--color-accent);
    background: rgb(255 255 255 / 0.06);
  }
</style>
