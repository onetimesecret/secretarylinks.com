---
interface Props {
  icon?: string;
  title: string;
  dark?: boolean;
}

const { icon, title, dark = false } = Astro.props;
---

<div
  data-reveal
  class:list={[
    'rounded-2xl border p-8 transition-all duration-300 hover:-translate-y-1',
    dark
      ? 'border-border-inv/8 bg-white/4 hover:border-accent'
      : 'border-border bg-surface-raised hover:border-accent hover:shadow-lg',
  ]}
>
  {icon && (
    <div class="mb-6 flex size-14 items-center justify-center rounded-xl bg-linear-to-br from-accent/10 to-accent-secondary/10 text-2xl">
      <Fragment set:html={icon} />
    </div>
  )}
  <h3 class="mb-2 text-xl">{title}</h3>
  <p class:list={['text-[0.95rem] leading-relaxed', dark ? 'text-text-inverse/60' : 'text-text-secondary']}>
    <slot />
  </p>
</div>
