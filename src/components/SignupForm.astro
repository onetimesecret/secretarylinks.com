---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<form data-signup class:list={['flex gap-2 max-w-md mx-auto max-sm:flex-col', className]}>
  <input
    type="email"
    name="fields[email]"
    required
    placeholder="you@company.com"
    aria-label="Email address"
    autocomplete="email"
    class="flex-1 rounded-lg border border-border-inv/15 bg-white/6 px-5 py-3.5 font-body text-text-inverse placeholder:text-text-inverse/40 outline-none transition focus:border-accent"
  />
  <button
    type="submit"
    class="rounded-lg bg-accent px-6 py-3.5 font-semibold text-accent-on transition hover:bg-accent-hover hover:-translate-y-px shrink-0"
  >
    Notify Me
  </button>
</form>

<script>
  const ML_FORM_URL = 'https://assets.mailerlite.com/jsonp/2184301/forms/181738487029957857/subscribe';

  document.querySelectorAll('[data-signup]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input') as HTMLInputElement;
      const btn = form.querySelector('button') as HTMLButtonElement;
      if (!input || !btn) return;

      btn.disabled = true;
      btn.textContent = 'Sending…';

      const body = new FormData();
      body.append('fields[email]', input.value);
      body.append('ml-submit', '1');
      body.append('anticsrf', 'true');

      try {
        const res = await fetch(ML_FORM_URL, { method: 'POST', body });
        if (res.ok) {
          btn.textContent = "You're on the list";
          input.disabled = true;
          input.value = '';
          input.placeholder = 'Check your inbox to confirm';
        } else {
          btn.textContent = 'Try again';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    });
  });
</script>
